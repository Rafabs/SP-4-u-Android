<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🚇"
        android:textSize="48sp"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ops... Estacao Nao Encontrada"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textAlignment="center"
        android:textColor="?attr/colorOnSurface"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="LINHA FORA DE OPERACAO"
        android:textSize="11sp"
        android:textStyle="bold"
        android:textColor="#D40000"
        android:letterSpacing="0.12"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Parece que o trem mudou de rota ou esta linha ainda esta em obras. Aguarde o proximo trem ou retorne a estacao anterior."
        android:textSize="14sp"
        android:textAlignment="center"
        android:textColor="?android:attr/textColorSecondary"
        android:lineSpacingMultiplier="1.6"/>

</LinearLayout>