<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#0F0F0F"> <!-- Mantendo o dark mode do app -->

    <!-- Canais de Informação -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Canais de Informação"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:fontFamily="sans-serif-medium"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Para notícias atualizadas sobre a regulação do transporte, concessões aeroportuárias e rodoviárias no estado, consulte os canais oficiais da ARTESP. Esses links fornecem acesso direto às últimas notícias, comunicados e atualizações sobre os sistemas de transporte sob regulação da agência.:"
        android:textColor="#CCCCCC"
        android:textSize="14sp"
        android:layout_marginBottom="16dp"/>

    <!-- Botões ARTESP -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnArtespMetro"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Notícias ARTESP | Metroviário"
        app:icon="@drawable/ic_newspaper"
        android:textColor="#673AB7"
        app:strokeColor="#A779FF"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnArtespRodovias"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Notícias ARTESP | Rodovias"
        app:icon="@drawable/ic_newspaper"
        android:textColor="#F44336"
        app:strokeColor="#F88C84"
        android:layout_marginTop="8dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnArtespAeroportos"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Notícias ARTESP | Aeroportos"
        app:icon="@drawable/ic_newspaper"
        android:textColor="#6ea8ff"
        app:strokeColor="#1a3aff"
        android:layout_marginTop="8dp"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#33FFFFFF"
        android:layout_marginVertical="24dp"/>

</LinearLayout>