<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.SP4u" parent="Theme.Material3.Dark.NoActionBar">
        <!-- Cor primária: vermelho SP -->
        <item name="colorPrimary">@color/sp_red</item>
        <item name="colorPrimaryVariant">@color/sp_red_dark</item>
        <item name="colorOnPrimary">@color/white</item>

        <!-- Cor secundária -->
        <item name="colorSecondary">@color/sp_red_light</item>
        <item name="colorOnSecondary">@color/white</item>

        <!-- Fundos escuros -->
        <item name="android:colorBackground">@color/bg_dark</item>
        <item name="colorSurface">@color/bg_card_dark</item>
        <item name="colorOnSurface">@color/text_primary_dark</item>

        <!-- Texto -->
        <item name="android:textColorPrimary">@color/text_primary_dark</item>
        <item name="android:textColorSecondary">@color/text_secondary_dark</item>

        <!-- Navigation Drawer -->
        <item name="navigationViewStyle">@style/Widget.SP4u.NavigationView</item>
    </style>

    <style name="Widget.SP4u.NavigationView" parent="Widget.Material3.NavigationView">
        <item name="itemIconTint">@color/sp_red</item>
        <item name="itemTextColor">@color/text_primary_dark</item>
    </style>
</resources>